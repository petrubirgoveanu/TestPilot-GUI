# Environment template for TestPilot.
# Use placeholders only. Do not commit real secrets.

# Optional: OpenRouter API key used only when DEMO_MODE=false.
OPENROUTER_API_KEY=<your_openrouter_api_key>

# Model identifier for OpenRouter-compatible ChatOpenAI client.
LLM_MODEL=<your_llm_model>

# true: deterministic fallback mode, false: allow real LLM calls when key exists.
DEMO_MODE=<true_or_false>

# Storefront base URL used by Playwright for mutation paths:
# BASE_URL/index.html?mutation=baseline
# BASE_URL/index.html?mutation=testid_removed
BASE_URL=<your_storefront_base_url>

# LangSmith tracing toggle.
LANGSMITH_TRACING=<true_or_false>

# Optional: LangSmith API key (used only when tracing is enabled).
LANGSMITH_API_KEY=<your_langsmith_api_key>

# Optional: LangSmith project name.
LANGSMITH_PROJECT=<your_langsmith_project>

# Optional: LangSmith endpoint.
LANGSMITH_ENDPOINT=<your_langsmith_endpoint>

# Optional local override. Render provides PORT automatically at runtime.
PORT=<your_port>
