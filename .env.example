# Copy this file to .env and fill in your values

# Optional: OpenRouter API key for LLM-backed flows
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
DEMO_MODE=true

# Local URL used by the demo storefront server for Playwright.
# Start the storefront separately with: python -m http.server 8080 --directory demo_site
BASE_URL=http://localhost:8080

# Optional: LangSmith tracing configuration
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=testpilot-hackathon
# Optional: LangSmith endpoint. Set this if your LangSmith project requires a custom endpoint.
# Example: https://api.smith.langchain.com
LANGSMITH_ENDPOINT=
